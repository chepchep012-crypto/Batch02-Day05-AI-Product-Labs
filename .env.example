# =============================================================================
# AI Provider Configuration
# =============================================================================
# Chọn provider bằng biến AI_PROVIDER (hoặc để trống để tự auto-detect)
# Giá trị hợp lệ: openai | gemini | claude | openrouter | ollama
# Auto-detect thứ tự: OPENAI_API_KEY → GEMINI_API_KEY → CLAUDE_API_KEY → OPENROUTER_API_KEY → ollama
# =============================================================================

AI_PROVIDER=

# -----------------------------------------------------------------------------
# OpenAI (GPT)
# Lấy key tại: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
# Các model khác: gpt-4o, gpt-4o-mini, gpt-4-turbo

# -----------------------------------------------------------------------------
# Google Gemini
# Lấy key tại: https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Các model khác: gemini-1.5-pro, gemini-2.0-flash

# -----------------------------------------------------------------------------
# Anthropic Claude
# Lấy key tại: https://console.anthropic.com/
# -----------------------------------------------------------------------------
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku-20240307
# Các model khác: claude-3-5-sonnet-20241022, claude-3-opus-20240229

# -----------------------------------------------------------------------------
# OpenRouter (truy cập nhiều model qua 1 API key)
# Lấy key tại: https://openrouter.ai/keys
# Danh sách model: https://openrouter.ai/models
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-3.5-turbo
# Các model khác: anthropic/claude-3.5-sonnet, google/gemini-flash-1.5, meta-llama/llama-3.1-8b-instruct:free

# -----------------------------------------------------------------------------
# Ollama (chạy local, không cần API key)
# Cài Ollama: https://ollama.com/download
# Pull model: ollama pull llama3
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Các model khác: mistral, phi3, gemma2, qwen2

# -----------------------------------------------------------------------------
# Backend config
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
